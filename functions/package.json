    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1001.0",
    "cors": "^2.8.6",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.6.0",
    "jsonwebtoken": "^9.0.2",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.2",
    "@types/validator": "^13.12.0",
    "typescript": "^5.5.4"
  },
  "private": true
