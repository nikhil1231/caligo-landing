---
import { whyIMadeCaligoSection } from '../../content/copy';
---

<section id="why-i-made-caligo" class="pb-8 pt-10 md:pb-12 md:pt-16">
  <div class="section-grid">
    <div class="grid items-center gap-8 rounded-3xl border border-sky-100/70 bg-white/80 p-6 shadow-soft md:grid-cols-[1.35fr_1fr] md:gap-12 md:p-10">
      <div>
        <p class="eyebrow mb-3">{whyIMadeCaligoSection.eyebrow}</p>
        <h2 class="text-2xl font-extrabold leading-tight md:text-4xl">{whyIMadeCaligoSection.title}</h2>
        <div class="mt-5 space-y-4 text-sm leading-relaxed text-muted md:text-base">
          {whyIMadeCaligoSection.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </div>

      <div class="flex justify-center md:justify-end">
        <img
          src={whyIMadeCaligoSection.imageSrc}
          alt={whyIMadeCaligoSection.imageAlt}
          class="mx-auto aspect-square w-full max-w-[280px] rounded-full border border-white/90 bg-white p-1 object-contain shadow-lg"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
