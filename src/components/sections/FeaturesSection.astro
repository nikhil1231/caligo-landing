---
import { features, featuresSection } from '../../content/copy';
import FeatureCard from '../ui/FeatureCard.astro';
import SectionShell from '../ui/SectionShell.astro';
---

<SectionShell
  id="features"
  eyebrow={featuresSection.eyebrow}
  title={featuresSection.title}
  lead={featuresSection.lead}
>
  <div class="grid gap-4 md:grid-cols-2 md:gap-6">
    {
      features.map((feature) => (
        <FeatureCard icon={feature.icon} title={feature.title} body={feature.body} />
      ))
    }
  </div>
</SectionShell>
