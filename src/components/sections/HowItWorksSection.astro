---
import { howItWorks } from '../../content/copy';
import SectionShell from '../ui/SectionShell.astro';
---

<SectionShell
  id="how-it-works"
  eyebrow={howItWorks.eyebrow}
  title={howItWorks.title}
  lead={howItWorks.lead}
>
  <ol class="grid gap-4 md:grid-cols-3 md:gap-6">
    {
      howItWorks.steps.map((step, index) => (
        <li class="surface-card h-full p-6 md:p-7">
          <div class="mb-4 flex items-center gap-3">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-accent/15 text-sm font-bold text-accent">
              {index + 1}
            </span>
            <span class="inline-flex rounded-full bg-accent/12 p-2 text-accent" aria-hidden="true">
              <i data-lucide={step.icon}></i>
            </span>
          </div>
          <h3 class="text-lg font-bold leading-snug">{step.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{step.body}</p>
        </li>
      ))
    }
  </ol>
</SectionShell>
