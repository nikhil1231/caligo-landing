---
import { testimonials } from '../../content/copy';
import SectionShell from '../ui/SectionShell.astro';
---

<SectionShell
  eyebrow="Testimonials"
  title="Early feedback from routine-focused testers"
  lead="Placeholder quotes for launch. Replace with verified customer testimonials before production."
>
  <div class="grid gap-4 md:grid-cols-3 md:gap-6">
    {
      testimonials.map((item) => (
        <blockquote class="surface-card h-full p-6 md:p-7">
          <p class="text-sm leading-relaxed text-ink md:text-base">“{item.quote}”</p>
          <footer class="mt-5 border-t border-slate-100 pt-4">
            <p class="text-sm font-semibold">{item.author}</p>
            <p class="text-xs text-muted">{item.detail}</p>
          </footer>
        </blockquote>
      ))
    }
  </div>
</SectionShell>
