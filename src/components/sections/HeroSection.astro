---
import { heroCopy } from '../../content/copy';
import { homeSectionLink, withBasePath } from '../../lib/site';
import Button from '../ui/Button.astro';
---

<section class="relative overflow-hidden pb-14 pt-14 md:pb-20 md:pt-20">
  <div class="soft-blob -left-24 top-6 h-56 w-56 bg-accent/25"></div>
  <div class="soft-blob -right-16 top-14 h-72 w-72 bg-sky-300/28"></div>

  <div class="section-grid">
    <div class="mx-auto max-w-4xl text-center">
      <p class="eyebrow mb-5">{heroCopy.eyebrow}</p>
      <h1 class="text-balance text-4xl font-extrabold leading-tight md:text-6xl">{heroCopy.headline}</h1>
      <p class="mx-auto mt-6 max-w-3xl text-base leading-relaxed text-muted md:text-xl">{heroCopy.subtext}</p>

      <p class="mx-auto mt-8 text-sm font-medium text-slate-400 md:mt-10">{heroCopy.qualifier}</p>

      <div class="mt-4 flex flex-wrap items-center justify-center gap-3 md:mt-5">
        <Button
          as="a"
          href={homeSectionLink('#waitlist')}
          data-analytics-event="cta_click"
          data-analytics-target="waitlist"
          data-analytics-label="hero_get_early_access"
          data-analytics-location="hero"
        >
          Get Early Access
          <i data-lucide="arrow-right" class="ml-2"></i>
        </Button>
      </div>
    </div>
  </div>
</section>
