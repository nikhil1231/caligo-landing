---
import { trustNotes } from '../../content/copy';
import SectionShell from '../ui/SectionShell.astro';
---

<SectionShell
  eyebrow="Trust and safety"
  title={trustNotes.title}
  lead="Caligo supports long-term health habits with neutral language and clear boundaries."
>
  <div class="surface-card space-y-5 p-6 md:p-8">
    <ul class="space-y-4">
      {
        trustNotes.points.map((point) => (
          <li class="flex items-start gap-3 text-sm leading-relaxed text-muted md:text-base">
            <span class="mt-0.5 inline-flex rounded-full bg-accent/15 p-1.5 text-accent" aria-hidden="true">
              <i data-lucide="shield"></i>
            </span>
            <span>{point}</span>
          </li>
        ))
      }
    </ul>
    <p class="text-sm leading-relaxed text-muted md:text-base">
      Need support now?
      <a href={trustNotes.resourceHref} target="_blank" rel="noopener noreferrer" class="font-semibold text-accent hover:text-sky-500">
        {trustNotes.resourceLabel}
      </a>
    </p>
  </div>
</SectionShell>
