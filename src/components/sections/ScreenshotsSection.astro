---
import { readdirSync } from 'node:fs';
import { resolve } from 'node:path';
import { screenshotCards as screenshotCopyCards, screenshotsSection } from '../../content/copy';
import DeviceFrame from '../ui/DeviceFrame.astro';
import SectionShell from '../ui/SectionShell.astro';

type ScreenshotCard = {
  src: string;
  alt: string;
  caption: string;
};

const screenshotsDir = resolve(process.cwd(), 'public', 'screenshots');

let files: string[] = [];

try {
  files = readdirSync(screenshotsDir, { withFileTypes: true })
    .filter((entry) => entry.isFile())
    .map((entry) => entry.name);
} catch {
  files = [];
}

const screenshotCards: ScreenshotCard[] = files
  .filter((name) => /^screen_(\d+)\.webp$/i.test(name))
  .sort((a, b) => {
    const aNumber = Number((a.match(/^screen_(\d+)\.webp$/i) ?? [])[1] ?? 0);
    const bNumber = Number((b.match(/^screen_(\d+)\.webp$/i) ?? [])[1] ?? 0);
    return aNumber - bNumber;
  })
  .map((name, index) => {
    const copyItem = screenshotCopyCards[index];

    return {
      src: `/screenshots/${name}`,
      alt: copyItem?.alt ?? 'Caligo app screenshot',
      caption: copyItem?.caption ?? 'Caligo app'
    };
  });
---

<SectionShell
  eyebrow={screenshotsSection.eyebrow}
  title={screenshotsSection.title}
  lead={screenshotsSection.lead}
>
  <div class="group relative mt-10">
    <button data-carousel-prev class="absolute left-2 md:-left-6 lg:-left-8 top-1/2 z-10 flex h-12 w-12 -translate-y-[calc(50%+1rem)] items-center justify-center rounded-full bg-white/90 backdrop-blur border border-slate-200 shadow-md text-slate-700 transition hover:bg-white hover:text-accent opacity-90 hover:opacity-100 active:scale-95" aria-label="Previous screenshot">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>

    <div data-carousel class="-mx-4 flex gap-6 overflow-x-auto px-[10vw] pb-4 snap-x snap-mandatory md:mx-0 md:px-0 scroll-smooth [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {
        screenshotCards.map((item) => (
          <div class="w-[80vw] shrink-0 snap-center md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
            <DeviceFrame src={item.src} alt={item.alt} caption={item.caption} />
          </div>
        ))
      }
    </div>

    <button data-carousel-next class="absolute right-2 md:-right-6 lg:-right-8 top-1/2 z-10 flex h-12 w-12 -translate-y-[calc(50%+1rem)] items-center justify-center rounded-full bg-white/90 backdrop-blur border border-slate-200 shadow-md text-slate-700 transition hover:bg-white hover:text-accent opacity-90 hover:opacity-100 active:scale-95" aria-label="Next screenshot">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>

    <div class="mt-8 flex justify-center gap-2" data-carousel-dots aria-hidden="true">
      {
        screenshotCards.map((_, i) => (
          <button
            type="button"
            class="h-2 w-2 rounded-full bg-slate-200 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 aria-[current=true]:w-6 aria-[current=true]:bg-accent"
            aria-label={`Go to slide ${i + 1}`}
            data-index={i}
          ></button>
        ))
      }
    </div>
  </div>
</SectionShell>

<script>
  function initCarousels() {
    const carousels = document.querySelectorAll<HTMLElement>('[data-carousel]');

    carousels.forEach(carousel => {
      const parent = carousel.parentElement;
      if (!parent) return;

      const prevBtn = parent.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextBtn = parent.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const dotsContainer = parent.querySelector<HTMLElement>('[data-carousel-dots]');
      const dots = dotsContainer ? Array.from(dotsContainer.querySelectorAll('button')) : [];
      const items = Array.from(carousel.children) as HTMLElement[];

      let interval: ReturnType<typeof setInterval>;
      let activeIndex = 0;

      const updateDots = () => {
        dots.forEach((dot, index) => {
          dot.setAttribute('aria-current', index === activeIndex ? 'true' : 'false');
        });
      };

      const scrollNext = () => {
        if (!carousel) return;
        const item = items[0];
        if (!item) return;

        const itemWidth = item.offsetWidth;
        const gap = 24; // 1.5rem spacing

        // Loop back if near end
        if (carousel.scrollLeft + carousel.clientWidth >= carousel.scrollWidth - 10) {
          carousel.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          carousel.scrollBy({ left: itemWidth + gap, behavior: 'smooth' });
        }
      };

      const scrollPrev = () => {
        if (!carousel) return;
        const item = items[0];
        if (!item) return;

        const itemWidth = item.offsetWidth;
        const gap = 24;

        // Loop to end if at start
        if (carousel.scrollLeft <= 0) {
          carousel.scrollTo({ left: carousel.scrollWidth, behavior: 'smooth' });
        } else {
          carousel.scrollBy({ left: -(itemWidth + gap), behavior: 'smooth' });
        }
      };

      const startAutoScroll = () => {
        if (interval) clearInterval(interval);
        interval = setInterval(scrollNext, 5000);
      };

      const stopAutoScroll = () => {
        if (interval) clearInterval(interval);
      };

      // Intersection Observer for active dot
      if (items.length > 0) {
        const observer = new IntersectionObserver(
          (entries) => {
            let maxVisibleRatio = 0;
            let mostVisibleIndex = activeIndex;

            entries.forEach((entry) => {
              if (entry.isIntersecting && entry.intersectionRatio > maxVisibleRatio) {
                maxVisibleRatio = entry.intersectionRatio;
                mostVisibleIndex = items.indexOf(entry.target as HTMLElement);
              }
            });

            if (maxVisibleRatio > 0 && mostVisibleIndex !== activeIndex) {
              activeIndex = mostVisibleIndex;
              updateDots();
            }
          },
          {
            root: carousel,
            threshold: 0.5,
          }
        );

        items.forEach((item) => observer.observe(item));
        updateDots();
      }

      // Dot click handling
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          stopAutoScroll();
          const target = items[index];
          if (target) {
            // Scroll inline center so the clicked item sits right in the middle
            target.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
            startAutoScroll();
          }
        });
      });

      // Navigation
      nextBtn?.addEventListener('click', () => {
        stopAutoScroll();
        scrollNext();
        startAutoScroll(); // restart timer
      });

      prevBtn?.addEventListener('click', () => {
        stopAutoScroll();
        scrollPrev();
        startAutoScroll();
      });

      // Pause on interactions
      carousel.addEventListener('mouseenter', stopAutoScroll);
      carousel.addEventListener('touchstart', stopAutoScroll, { passive: true });
      parent.addEventListener('focusin', stopAutoScroll);

      // Resume on leave
      carousel.addEventListener('mouseleave', startAutoScroll);
      carousel.addEventListener('touchend', () => {
        // slight delay to avoid immediate scroll after touch
        setTimeout(startAutoScroll, 1000);
      });
      parent.addEventListener('focusout', startAutoScroll);

      startAutoScroll();
    });
  }

  // Initialize
  initCarousels();
  document.addEventListener('astro:page-load', initCarousels);
</script>
