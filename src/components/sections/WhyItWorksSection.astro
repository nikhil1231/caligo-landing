---
import { whyItWorks } from '../../content/copy';
---

<section id="why-it-works" class="pb-20 pt-4">
  <div class="section-grid">
    <div class="relative mx-auto max-w-4xl px-4 md:px-8">

      <!-- Split 2-col Layout -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-10 md:gap-16 relative before:absolute before:inset-0 before:-z-10 before:rounded-3xl before:bg-sky-50/90 before:border before:border-sky-100/50 p-6 md:p-10">

        {/* Left Column: Text */}
        <div class="flex-1 md:max-w-[480px]">
          <p class="mb-4 text-xs font-bold tracking-[0.15em] text-accent/70 uppercase">{whyItWorks.eyebrow}</p>
          <h2 class="mb-4 text-xl font-extrabold leading-tight tracking-tight text-slate-900 md:text-2xl">{whyItWorks.title}</h2>
          <p class="text-[15px] leading-relaxed text-slate-600">{whyItWorks.lead}</p>

          {whyItWorks.kicker && (
            <div class="mt-6 flex items-center gap-2">
              <i data-lucide="check-circle-2" class="h-4 w-4 text-accent/80"></i>
              <p class="text-sm font-medium text-slate-500">{whyItWorks.kicker}</p>
            </div>
          )}
        </div>

        {/* Right Column: Visual */}
        <div class="bg-white rounded-2xl p-5 border border-slate-100 shadow-[0_2px_12px_-4px_rgba(0,0,0,0.05)] flex-shrink-0 w-full md:w-auto md:min-w-[240px] flex items-center justify-center gap-4">
           <div class="h-10 w-10 rounded-full bg-accent/10 flex items-center justify-center text-accent">
             <i data-lucide="line-chart" class="h-5 w-5"></i>
           </div>
           <div>
             <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-0.5">Calibration</p>
             <p class="font-bold text-slate-900">~14 days</p>
           </div>
        </div>

      </div>
    </div>
  </div>
</section>
