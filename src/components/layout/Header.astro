---
import { navItems } from '../../content/copy';
import { homeSectionLink, withBasePath } from '../../lib/site';
import Button from '../ui/Button.astro';
---

<header class="sticky top-0 z-50 border-b border-white/60 bg-[#f8fcff]/90 backdrop-blur">
  <div class="section-grid flex items-center justify-between gap-4 py-3">
    <a href={withBasePath('/')} aria-label="Caligo Tracker home" class="inline-flex items-center gap-3">
      <span
        class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-gradient-to-br from-accent to-sky-300 text-lg font-bold text-white"
      >
        C
      </span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-medium text-muted md:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={homeSectionLink(item.href)} class="transition hover:text-ink">
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <Button as="a" href={withBasePath('/contact')} variant="secondary" size="sm" class="hidden sm:inline-flex">
        Get TestFlight link
      </Button>
      <Button as="a" href={homeSectionLink('#waitlist')} size="sm">
        Join the waitlist
      </Button>
    </div>
  </div>
</header>
