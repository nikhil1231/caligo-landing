---
import { navItems } from '../../content/copy';
import { homeSectionLink, withBasePath } from '../../lib/site';
import Button from '../ui/Button.astro';
---

<header class="sticky top-0 z-50 border-b border-white/60 bg-sky-50/90 backdrop-blur">
  <div class="section-grid flex items-center justify-between gap-4 py-6">
    <a href={withBasePath('/')} aria-label="Caligo Tracker home" class="inline-flex items-center gap-4">
      <img
        src={withBasePath('/icon_full.png')}
        alt="logo"
        draggable="false"
        class="h-11 w-11"
      />
      <span class="text-2xl font-bold tracking-tight text-ink">Caligo</span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-medium text-muted md:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a href={homeSectionLink(item.href)} class="transition hover:text-ink">
            {item.label}
          </a>
        ))
      }
      <a href={withBasePath('/contact')} class="transition hover:text-ink">Contact</a>
    </nav>

    <div class="flex items-center gap-2 md:gap-3">
      <div id="header-cta-wrapper" class="opacity-0 pointer-events-none transition-opacity duration-300">
        <Button
          as="a"
          href={homeSectionLink('#waitlist')}
          size="sm"
          data-analytics-event="cta_click"
          data-analytics-target="waitlist"
          data-analytics-label="header_get_early_access"
          data-analytics-location="header"
        >
          Get Early Access
        </Button>
      </div>
    </div>
  </div>
</header>

<script>
  function setupHeaderScroll() {
    const wrapper = document.getElementById('header-cta-wrapper');
    if (!wrapper) return;

    const handleScroll = () => {
      // Show the button when scrolled down by 150px
      if (window.scrollY > 150) {
        wrapper.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        wrapper.classList.add('opacity-0', 'pointer-events-none');
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    // Set initial state
    handleScroll();
  }

  // Setup on initial load
  setupHeaderScroll();

  // Support Astro View Transitions if enabled
  document.addEventListener('astro:page-load', setupHeaderScroll);
</script>
