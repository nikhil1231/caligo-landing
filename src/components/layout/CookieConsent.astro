<div
  class="pointer-events-none fixed inset-0 z-[120] hidden"
  data-cookie-consent-modal
  aria-hidden="true"
>
  <div class="absolute inset-0 bg-slate-950/50" data-cookie-consent-backdrop></div>

  <section
    class="absolute inset-x-4 bottom-4 mx-auto w-full max-w-2xl rounded-3xl border border-slate-200 bg-white p-6 shadow-2xl md:p-7"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cookie-consent-title"
    aria-describedby="cookie-consent-description"
  >
    <div data-cookie-view="banner">
      <h2 id="cookie-consent-title" class="text-lg font-extrabold text-ink">Cookie preferences</h2>
      <p id="cookie-consent-description" class="mt-3 text-sm leading-6 text-muted md:text-base">
        We use necessary cookies to make the site work. With your permission, we'd also like to use
        analytics cookies to understand what's working and improve Caligo. You can accept all, reject
        non-essential cookies, or choose your preferences.
      </p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <button
          type="button"
          class="inline-flex flex-1 items-center justify-center rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-500 focus-visible:outline-none"
          data-cookie-action="accept"
        >
          Accept all
        </button>
        <button
          type="button"
          class="inline-flex flex-1 items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none"
          data-cookie-action="reject"
        >
          Reject non-essential
        </button>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-full border border-transparent px-5 py-2.5 text-sm font-semibold text-accent transition hover:bg-sky-50 focus-visible:outline-none"
          data-cookie-action="manage"
        >
          Manage preferences
        </button>
      </div>
    </div>

    <div class="hidden" data-cookie-view="preferences">
      <h2 class="text-lg font-extrabold text-ink">Manage cookie preferences</h2>
      <p class="mt-2 text-sm leading-6 text-muted">
        Choose which cookies you want to allow. You can update these settings anytime.
      </p>

      <div class="mt-5 space-y-3">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-sm font-semibold text-ink">Necessary</p>
              <p class="text-xs text-muted">Always on</p>
            </div>
            <span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold text-slate-700"
              >Always on</span
            >
          </div>
        </div>

        <label class="flex items-center justify-between gap-4 rounded-2xl border border-slate-200 px-4 py-3">
          <div>
            <span class="block text-sm font-semibold text-ink">Analytics</span>
            <span class="block text-xs text-muted">Off by default</span>
          </div>
          <input
            type="checkbox"
            class="h-5 w-5 cursor-pointer accent-accent"
            data-cookie-analytics-toggle
          />
        </label>
      </div>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-sky-500 focus-visible:outline-none"
          data-cookie-action="save"
        >
          Save preferences
        </button>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-full border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-slate-400 hover:bg-slate-50 focus-visible:outline-none"
          data-cookie-action="back"
        >
          Back
        </button>
      </div>
    </div>
  </section>
</div>

<script>
  import { initCookieConsent } from '../../scripts/cookieConsent';

  void initCookieConsent();
</script>
