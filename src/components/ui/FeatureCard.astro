---
interface Props {
  icon: string;
  title: string;
  body: string;
}

const { icon, title, body } = Astro.props as Props;
---

<article class="surface-card h-full p-6 md:p-7">
  <div class="mb-4 inline-flex rounded-full bg-accent/12 p-3 text-accent" aria-hidden="true">
    <i data-lucide={icon}></i>
  </div>
  <h3 class="text-lg font-bold">{title}</h3>
  <p class="mt-3 text-sm leading-relaxed text-muted md:text-base">{body}</p>
</article>
