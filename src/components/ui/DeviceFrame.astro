---
import { withBasePath } from '../../lib/site';

interface Props {
  src: string;
  alt: string;
  caption: string;
  fallbackSrc?: string;
}

const { src, alt, caption, fallbackSrc } = Astro.props as Props;
---

<figure class="mx-auto flex max-w-[278px] flex-col items-center gap-3">
  <div class="relative w-full overflow-hidden rounded-[2rem] border-8 border-slate-900 bg-slate-900 p-2 shadow-soft">
    {
      fallbackSrc ? (
        <picture>
          <source srcset={withBasePath(src)} type="image/webp" />
          <img
            src={withBasePath(fallbackSrc)}
            alt={alt}
            loading="lazy"
            decoding="async"
            class="media-soften h-[530px] w-full rounded-[1.4rem] bg-[#f5f6f8] object-contain object-top"
          />
        </picture>
      ) : (
        <img
          src={withBasePath(src)}
          alt={alt}
          loading="lazy"
          decoding="async"
          class="media-soften h-[530px] w-full rounded-[1.4rem] bg-[#f5f6f8] object-contain object-top"
        />
      )
    }
    <div class="pointer-events-none absolute left-1/2 top-0 h-5 w-24 -translate-x-1/2 rounded-b-2xl bg-slate-900"></div>
  </div>
  <figcaption class="text-sm font-medium text-muted">{caption}</figcaption>
</figure>
