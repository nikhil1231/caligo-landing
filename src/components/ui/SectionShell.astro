---
import clsx from 'clsx';

interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  lead?: string;
  class?: string;
}

const { id, eyebrow, title, lead, class: className } = Astro.props as Props;
---

<section id={id} class={clsx('py-14 md:py-20', className)}>
  <div class="section-grid">
    <div class="mb-8 max-w-3xl md:mb-10">
      {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
      <h2 class="text-2xl font-extrabold leading-tight md:text-4xl">{title}</h2>
      {lead && <p class="muted mt-4 max-w-2xl" set:html={lead} />}
    </div>
    <slot />
  </div>
</section>
