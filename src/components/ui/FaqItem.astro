---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props as Props;
---

<details class="surface-card group">
  <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-5 text-left font-semibold md:p-6">
    <span>{question}</span>
    <span class="mt-0.5 text-accent transition group-open:rotate-180" aria-hidden="true">
      <i data-lucide="chevron-down"></i>
    </span>
  </summary>
  <p class="px-5 pb-5 text-sm leading-relaxed text-muted md:px-6 md:pb-6 md:text-base">{answer}</p>
</details>
