---
import '../styles/global.css';
import { getAnalyticsConfig } from '../lib/analytics';
import { buildSeo } from '../lib/seo';
import { withBasePath } from '../lib/site';

interface Props {
  title?: string;
  description: string;
  path?: string;
  imagePath?: string;
  noIndex?: boolean;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  path = '/',
  imagePath = '/og-image.png',
  noIndex = false,
  type = 'website',
  jsonLd
} = Astro.props;

const seo = buildSeo({
  title,
  description,
  path,
  imagePath,
  noIndex,
  type
});

const analytics = getAnalyticsConfig();
const structuredData = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seo.fullTitle}</title>
    <meta name="description" content={seo.description} />
    <meta name="theme-color" content="#03a9f4" />
    <link rel="canonical" href={seo.canonical} />
    <link rel="icon" href={withBasePath('/favicon.ico')} sizes="any" />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <link rel="apple-touch-icon" href={withBasePath('/apple-touch-icon.png')} />

    <meta property="og:site_name" content="Caligo Tracker" />
    <meta property="og:title" content={seo.fullTitle} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:type" content={seo.type} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.fullTitle} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    {seo.noIndex && <meta name="robots" content="noindex, nofollow" />}

    {structuredData.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    {
      analytics?.provider === 'plausible' && (
        <script defer data-domain={analytics.key} src="https://plausible.io/js/script.js"></script>
      )
    }

    {
      analytics?.provider === 'ga4' && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.key}`}></script>
          <script
            is:inline
            set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${analytics.key}');`}
          />
        </>
      )
    }
  </head>
  <body>
    <slot />
    <script>
      import { createIcons } from 'lucide';
      import {
        ArrowDownUp,
        ArrowRight,
        CheckCircle2,
        ChevronDown,
        Hand,
        Heart,
        Info,
        LayoutDashboard,
        LineChart,
        Lock,
        Scale,
        Shield,
        ShieldAlert,
        SlidersHorizontal,
        TrendingUp,
        Zap
      } from 'lucide';

      createIcons({
        icons: {
          ArrowDownUp,
          ArrowRight,
          CheckCircle2,
          ChevronDown,
          Hand,
          Heart,
          Info,
          LayoutDashboard,
          LineChart,
          Lock,
          Scale,
          Shield,
          ShieldAlert,
          SlidersHorizontal,
          TrendingUp,
          Zap
        },
        attrs: {
          'stroke-width': '1.7'
        }
      });
    </script>
  </body>
</html>
