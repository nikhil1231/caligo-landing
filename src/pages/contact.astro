---
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import { contactCopy } from '../content/copy';
import MainLayout from '../layouts/MainLayout.astro';
import { CONTACT_EMAIL } from '../lib/site';
---

<MainLayout title="Contact" description={contactCopy.metaDescription} path="/contact">
  <Header />
  <main class="section-grid py-14 md:py-20">
    <section class="mx-auto grid w-full max-w-4xl gap-6 md:grid-cols-[1fr,1.2fr]">
      <article class="surface-card p-6 md:p-8">
        <p class="eyebrow mb-2">{contactCopy.hero.eyebrow}</p>
        <h1 class="text-3xl font-extrabold md:text-4xl">{contactCopy.hero.title}</h1>
        <p class="mt-4 text-sm text-muted md:text-base">
          {contactCopy.hero.leadPrefix}
          <a class="font-semibold text-accent hover:text-sky-500" href={`mailto:${CONTACT_EMAIL}`}>
            {CONTACT_EMAIL}
          </a>
          {contactCopy.hero.leadSuffix}
        </p>
      </article>

      <article class="surface-card p-6 md:p-8">
        <h2 class="text-xl font-bold">{contactCopy.form.title}</h2>
        <p class="mt-2 text-sm text-muted md:text-base">
          {contactCopy.form.lead}
        </p>

        <div id="contact-form-container">
          <form class="mt-6 space-y-4" data-lead-form data-source="contact" novalidate>
            <div>
              <label for="contact-email" class="mb-2 block text-sm font-semibold">{contactCopy.form.emailLabel}</label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder={contactCopy.form.emailPlaceholder}
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-accent/25 transition placeholder:text-slate-400 focus:border-accent focus:ring md:text-base"
              />
            </div>

            <div>
              <label for="contact-topic" class="mb-2 block text-sm font-semibold">{contactCopy.form.topicLabel}</label>
              <select
                id="contact-topic"
                name="topic"
                required
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-accent/25 transition focus:border-accent focus:ring md:text-base truncate pr-8"
              >
                <option value="" disabled selected hidden>Select an option...</option>
                {
                  contactCopy.form.topicOptions.map((option) => (
                    <option value={option.value}>{option.label}</option>
                  ))
                }
              </select>
            </div>

            <div>
              <label for="contact-message" class="mb-2 block text-sm font-semibold">{contactCopy.form.messageLabel}</label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                placeholder={contactCopy.form.messagePlaceholder}
                class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-accent/25 transition placeholder:text-slate-400 focus:border-accent focus:ring md:text-base"
              ></textarea>
            </div>

            <div class="hidden" aria-hidden="true">
              <label for="contact-company">Company</label>
              <input id="contact-company" name="company" type="text" autocomplete="off" tabindex="-1" />
            </div>

            <button
              type="submit"
              class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-500 disabled:cursor-not-allowed disabled:opacity-60"
            >
              {contactCopy.form.cta}
            </button>

            <p data-form-status class="text-sm text-muted" aria-live="polite"></p>
          </form>
        </div>

        <div id="contact-success" class="hidden mt-6 flex-col items-center justify-center rounded-2xl border border-sky-100 bg-sky-50 p-8 text-center" aria-live="polite">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-accent">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold">Thanks for your message!</h3>
          <p class="mt-2 text-sm text-muted">We have received your message and will get back to you shortly.</p>
        </div>
      </article>
    </section>
  </main>
  <Footer />
  <script>
    import { initLeadForms } from '../scripts/forms';

    initLeadForms();
  </script>
</MainLayout>
