---
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { CONTACT_EMAIL } from '../lib/site';

const description = 'Contact Caligo Tracker and request TestFlight access.';
---

<MainLayout title="Contact" description={description} path="/contact">
  <Header />
  <main class="section-grid py-14 md:py-20">
    <section class="mx-auto grid w-full max-w-4xl gap-6 md:grid-cols-[1fr,1.2fr]">
      <article class="surface-card p-6 md:p-8">
        <p class="eyebrow mb-2">Contact</p>
        <h1 class="text-3xl font-extrabold md:text-4xl">Let us know what you need</h1>
        <p class="mt-4 text-sm text-muted md:text-base">
          For partnerships, support, or TestFlight interest, email
          <a class="font-semibold text-accent hover:text-sky-500" href={`mailto:${CONTACT_EMAIL}`}>
            {CONTACT_EMAIL}
          </a>
          .
        </p>
      </article>

      <article class="surface-card p-6 md:p-8">
        <h2 class="text-xl font-bold">Send a message</h2>
        <p class="mt-2 text-sm text-muted md:text-base">
          This form is a front-end stub and uses the same safe submit flow as the waitlist.
        </p>

        <form class="mt-6 space-y-4" data-lead-form data-source="contact" novalidate>
          <div>
            <label for="contact-email" class="mb-2 block text-sm font-semibold">Email</label>
            <input
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-accent/25 transition placeholder:text-slate-400 focus:border-accent focus:ring md:text-base"
            />
          </div>

          <div>
            <label for="contact-message" class="mb-2 block text-sm font-semibold">Message</label>
            <textarea
              id="contact-message"
              name="message"
              rows="4"
              placeholder="Tell us what you are looking for."
              class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-accent/25 transition placeholder:text-slate-400 focus:border-accent focus:ring md:text-base"
            ></textarea>
          </div>

          <div class="hidden" aria-hidden="true">
            <label for="contact-company">Company</label>
            <input id="contact-company" name="company" type="text" autocomplete="off" tabindex="-1" />
          </div>

          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-sky-500 disabled:cursor-not-allowed disabled:opacity-60"
          >
            Send message
          </button>

          <p data-form-status class="text-sm text-muted" aria-live="polite"></p>
        </form>
      </article>
    </section>
  </main>
  <Footer />
  <script>
    import { initLeadForms } from '../scripts/forms';

    initLeadForms();
  </script>
</MainLayout>
