---
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import MainLayout from '../layouts/MainLayout.astro';

const description =
  'Privacy Policy for Caligo Tracker. Learn what we collect, why we collect it, and how we protect your data.';

const updatedAt = 'March 13, 2026';
---

<MainLayout title="Privacy Policy" description={description} path="/privacy">
  <Header />
  <main class="section-grid py-14 md:py-20">
    <article class="surface-card mx-auto max-w-3xl space-y-6 p-6 md:p-10">
      <header class="space-y-3">
        <p class="eyebrow">Legal</p>
        <h1 class="text-3xl font-extrabold md:text-4xl">Privacy Policy</h1>
        <p class="text-sm text-muted">Last updated: {updatedAt}</p>
      </header>

      <p class="text-sm leading-relaxed text-muted md:text-base">
        This Privacy Policy explains how Caligo Tracker collects, uses, and protects information. This document is a launch
        template and may change as the product evolves.
      </p>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">What we collect</h2>
        <ul class="list-disc space-y-2 pl-5 text-sm leading-relaxed text-muted md:text-base">
          <li>Email address if you join the waitlist or contact us.</li>
          <li>Optional anonymized usage analytics if analytics is enabled.</li>
          <li>Optional weight, calorie, and exercise logs stored locally now or in a future cloud sync option.</li>
        </ul>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">How we use data</h2>
        <ul class="list-disc space-y-2 pl-5 text-sm leading-relaxed text-muted md:text-base">
          <li>To respond to waitlist and contact requests.</li>
          <li>To improve product quality and usability.</li>
          <li>To provide app features if cloud sync is introduced later.</li>
        </ul>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">Data retention</h2>
        <p class="text-sm leading-relaxed text-muted md:text-base">
          We keep data only as long as needed for the stated purpose. Local demo submissions remain in your browser storage
          unless you clear it.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">Third parties</h2>
        <p class="text-sm leading-relaxed text-muted md:text-base">
          If analytics or backend services are enabled, providers like Firebase or Clarity may process anonymized usage
          events for hosting, form delivery, and product diagnostics.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">Your rights and choices</h2>
        <p class="text-sm leading-relaxed text-muted md:text-base">
          You can request access, correction, or deletion of your personal information by contacting
          <a class="font-semibold text-accent hover:text-sky-500" href="mailto:hello@caligotracker.com">
            hello@caligotracker.com
          </a>
          .
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">Medical disclaimer</h2>
        <p class="text-sm leading-relaxed text-muted md:text-base">
          Caligo Tracker is not for medical use and is not a substitute for professional healthcare advice, diagnosis, or
          treatment.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-xl font-bold">Policy changes</h2>
        <p class="text-sm leading-relaxed text-muted md:text-base">
          We may revise this policy from time to time. Material updates will be reflected by the "Last updated" date above.
        </p>
      </section>
    </article>
  </main>
  <Footer />
</MainLayout>
