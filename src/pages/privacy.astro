---
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { privacyCopy } from '../content/copy';

const { title, description, updatedAt, intro, sections } = privacyCopy;
---

<MainLayout title={title} description={description} path="/privacy">
  <Header />
  <main class="section-grid py-14 md:py-20">
    <article class="surface-card mx-auto max-w-3xl space-y-6 p-6 md:p-10">
      <header class="space-y-3">
        <p class="eyebrow">Legal</p>
        <h1 class="text-3xl font-extrabold md:text-4xl">{title}</h1>
        <p class="text-sm text-muted">Last updated: {updatedAt}</p>
      </header>

      <p class="text-sm leading-relaxed text-muted md:text-base">
        {intro}
      </p>

      {
        sections.map((section) => (
          <section class="space-y-3">
            <h2 class="text-xl font-bold">{section.title}</h2>
            {section.type === 'list' && section.items && (
              <ul class="list-disc space-y-2 pl-5 text-sm leading-relaxed text-muted md:text-base">
                {section.items.map((item) => (
                  <li set:html={item} />
                ))}
              </ul>
            )}
            {section.type === 'text' && section.content && (
              <p class="text-sm leading-relaxed text-muted md:text-base" set:html={section.content} />
            )}
            {section.type === 'html' && section.content && (
              <p class="text-sm leading-relaxed text-muted md:text-base" set:html={section.content} />
            )}
          </section>
        ))
      }
    </article>
  </main>
  <Footer />
</MainLayout>
